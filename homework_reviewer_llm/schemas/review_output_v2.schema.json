{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/homework-reviewer/review-output-v2.schema.json",
  "title": "HomeworkReviewOutputV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "student_feedback",
    "reviewer_report",
    "factor_analysis",
    "overall_score"
  ],
  "properties": {
    "student_feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "strengths", "issues", "recommendations"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "strengths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": { "type": "string", "minLength": 1 },
              "evidence_quote": { "type": "string" }
            }
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "severity"],
            "properties": {
              "text": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "enum": ["low", "medium", "high"] },
              "evidence_quote": { "type": "string" }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "actionable"],
            "properties": {
              "text": { "type": "string", "minLength": 1 },
              "actionable": { "type": "boolean" }
            }
          }
        }
      }
    },
    "reviewer_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "risk_assessment", "score_justification"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "risk_assessment": { "type": "string", "minLength": 1 },
        "score_justification": { "type": "string", "minLength": 1 },
        "rubric_scores": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [{ "type": "number" }, { "type": "string" }]
          }
        }
      }
    },
    "factor_analysis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factor_id", "how_used"],
        "properties": {
          "factor_id": {
            "type": "string",
            "enum": ["submission", "revision_history", "student_profile"]
          },
          "how_used": { "type": "string", "minLength": 1 },
          "impact_on_score": { "type": "string" }
        }
      }
    },
    "overall_score": { "type": "number" }
  }
}
