APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Minimum secure staging (when the API is reachable beyond trusted localhost users) ---
# Set REQUIRE_AUTH_FOR_WRITES=true and configure SUPABASE_JWT_SECRET or SUPABASE_JWKS_URL.
# Set REQUIRE_AUTH_FOR_DEBUG_ROUTES=true so /api/v1/debug/* and /api/v1/projects/{id}/debug/* require JWT.
# For RL write endpoints, enable REQUIRE_AUTH_FOR_RL_WRITES=true when ENABLE_RL_ENGINE=true.
# See README: "Public staging / security (minimum)".

DATABASE_URL=sqlite:///./data/review_assistant.db
FILES_ROOT=./data/files
EXPORTS_ROOT=./data/exports
# Optional CORS for SPA on another origin (comma-separated). Empty = disabled.
# Exposes X-Total-Count, X-Total-Count-Truncated, X-Next-Cursor for GET /projects pagination.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
# CORS_ALLOW_CREDENTIALS=false

# Max upload size per file (bytes)
MAX_UPLOAD_BYTES=104857600
# When true, Playwright capture only allows https://*.datalens.yandex* / yandexcloud hosts
DATALENS_URL_ALLOWLIST_ENABLED=true
DEFAULT_STYLE_PROFILE=alex_review_v1
ENABLE_BROWSER_CAPTURE=false
BROWSER_CAPTURE_TIMEOUT_MS=15000
# Bounded thread pool for Playwright (0 = always inline)
CAPTURE_POOL_WORKERS=2
CAPTURE_POOL_TIMEOUT_SEC=120
CAPTURE_USE_POOL=true
DATALENS_SETTLE_AFTER_LOAD_MS=450
DATALENS_TAB_SETTLE_MS=550
DATALENS_MAX_TAB_SCREENSHOTS=4
# Playwright: retries for navigation / tab clicks (exponential backoff base)
DATALENS_GOTO_MAX_RETRIES=3
DATALENS_TAB_CLICK_MAX_RETRIES=2
DATALENS_STEP_RETRY_BASE_MS=400

# Finding quality (required fail below confidence → warn + manual review hints)
FINDING_POLICY_ENABLED=true
FINDING_MIN_CONFIDENCE_FOR_REQUIRED_FAIL=0.55
# Whole review pipeline wall timeout (0 = off)
REVIEW_PIPELINE_TIMEOUT_SEC=0
# Execute student .ipynb via nbclient before static review (requires ipykernel)
ENABLE_NOTEBOOK_EXECUTION=true
NOTEBOOK_EXECUTION_TIMEOUT_SEC=120
REVIEW_STRUCTURED_LOGS=true

# Optional OpenAI-compatible LLM (disabled by default — rule engine still runs)
ENABLE_LLM=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
ENABLE_LLM_COMMENT_GENERATION=false
ENABLE_LLM_SEMANTIC_CHECKS=false
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT_SEC=1.0
LLM_RETRY_MAX_WAIT_SEC=20.0
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_COOLDOWN_SEC=60.0

# Experimental RL engine addon
ENABLE_RL_ENGINE=false
# Optional (falls back to LLM_API_KEY / LLM_MODEL if unset)
# RL_OPENAI_API_KEY=
RL_OPENAI_MODEL=gpt-4o-mini
# RL_OPENAI_BASE_URL=https://api.openai.com/v1
# RL_MODELS_ROOT=./data/rl_models
# RL_TRAIN_MAX_TIMESTEPS=500000
# RL_TRAIN_MAX_CONCURRENT=2
# REQUIRE_AUTH_FOR_RL_WRITES=false
# RL_TRAIN_ASYNC_EXECUTOR=background_tasks
# RL_TRAIN_WORKER_POLL_SEC=1.5
# Gymnasium (optional): pip install -e ".[rl]"
# Stable-Baselines3 + PyTorch (optional, heavy): pip install -e ".[rl,rl_sb3]"

# Prefer Alembic on startup (falls back to create_all if upgrade fails)
USE_ALEMBIC_MIGRATIONS=true

# Optional local retrieval examples (JSONL: example_id, criterion_code, text, tags)
ENABLE_RETRIEVAL=false
# REVIEW_EXAMPLES_PATH=./data/review_examples.jsonl
# Optional: эталонные формулировки из ноутбука старшего ревьюера (Colab → JSONL). Не рубрика и не ground truth.
# ENABLE_REVIEWER_REFERENCE_EXAMPLES=false
# REVIEWER_REFERENCE_EXAMPLES_PATH=./data/reviewer_reference_examples.jsonl
# Корпус из нескольких master-review .ipynb (scripts/build_review_training_corpus.py): один .jsonl или каталог *.jsonl
# ENABLE_PROJECT_REVIEW_TRAINING=false
# PROJECT_REVIEW_TRAINING_PATH=./data/project_training.jsonl
# Глобальный фильтр по source_project в JSONL (если не задан review_training_project при upload)
# PROJECT_REVIEW_TRAINING_FILTER_PROJECT=my_project_slug

# Hybrid / semantic retrieval (requires numpy; local embeddings need pip install -e .[analysis])
# ENABLE_SEMANTIC_RETRIEVAL=false
# EMBEDDING_MODEL=local
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RETRIEVAL_INDEX_DIR=./data/retrieval_index
# RETRIEVAL_HYBRID_ALPHA=0.5
# RETRIEVAL_USE_FAISS=false

# Supabase (optional)
# SUPABASE_JWT_SECRET=
# SUPABASE_JWKS_URL=https://xxxx.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=projects-files
# REQUIRE_AUTH_FOR_WRITES=false
# When true, all /api/v1/debug/* and /api/v1/projects/{id}/debug/* require Supabase JWT (see SUPABASE_* above)
# REQUIRE_AUTH_FOR_DEBUG_ROUTES=false
